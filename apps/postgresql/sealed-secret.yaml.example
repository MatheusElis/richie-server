# Este arquivo deve ser gerado com o comando abaixo.
# A senha do superusuário postgres NUNCA deve ser commitada em texto plano.
#
# Como gerar:
#   kubectl create secret generic postgresql-credentials \
#     --namespace postgresql \
#     --from-literal=postgres-password=SUA_SENHA_AQUI \
#     --dry-run=client -o yaml \
#     | kubeseal --cert ~/.homelab/sealed-secrets-cert.pem \
#     -o yaml > apps/postgresql/sealed-secret.yaml
#
# Depois: git add apps/postgresql/sealed-secret.yaml && git commit
