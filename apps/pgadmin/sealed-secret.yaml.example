# Este arquivo deve ser gerado com o comando abaixo.
# As credenciais do pgAdmin NUNCA devem ser commitadas em texto plano.
#
# Como gerar:
#   kubectl create secret generic pgadmin-credentials \
#     --namespace pgadmin \
#     --from-literal=email=admin@bisnaguete.xyz \
#     --from-literal=password=SUA_SENHA_AQUI \
#     --dry-run=client -o yaml \
#     | kubeseal --cert ~/.homelab/sealed-secrets-cert.pem \
#     -o yaml > apps/pgadmin/sealed-secret.yaml
#
# Depois: git add apps/pgadmin/sealed-secret.yaml && git commit
