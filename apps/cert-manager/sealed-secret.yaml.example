# Este arquivo deve ser gerado pelo usuário com o comando abaixo.
# O token do Cloudflare NUNCA deve ser commitado em texto plano.
#
# Pré-requisito: make gen-keys já executado e cluster rodando
#
# Como gerar:
#   kubectl create secret generic cloudflare-api-token \
#     --namespace cert-manager \
#     --from-literal=api-token=SEU_TOKEN_AQUI \
#     --dry-run=client -o yaml \
#     | kubeseal --cert ~/.homelab/sealed-secrets-cert.pem \
#     -o yaml > apps/cert-manager/sealed-secret.yaml
#
# Depois: git add apps/cert-manager/sealed-secret.yaml && git commit
