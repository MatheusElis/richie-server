# Este arquivo deve ser gerado com o comando abaixo.
# As credenciais do Memos NUNCA devem ser commitadas em texto plano.
#
# Como gerar:
#   ./scripts/seal.sh memos-credentials memos \
#     postgresql-password=SUA_SENHA \
#     postgresql-superuser-password=SENHA_SUPERUSER \
#     dsn="postgresql://memos:SUA_SENHA@postgresql.postgresql.svc:5432/memos?sslmode=disable" \
#     > apps/memos/sealed-secret.yaml
#
# Depois: git add apps/memos/sealed-secret.yaml && git commit
